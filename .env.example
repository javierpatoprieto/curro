# =============================================================================
# AtiendeReformas — variables de entorno
# Copia este fichero a .env.local y rellena lo que necesites.
# En desarrollo, deja MOCK_PROVIDERS=true para no depender de cuentas externas.
# NUNCA subas .env.local al repositorio.
# =============================================================================

# --- Supabase --------------------------------------------------------------
# En Supabase: Project Settings → API. La "Project URL" y la "anon public" key.
# (En Next, el cliente de navegador necesita el prefijo NEXT_PUBLIC_.)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# La "service_role" key: SOLO servidor (webhooks, onboarding). Salta RLS.
SUPABASE_SERVICE_ROLE_KEY=

# --- Voz IA (Vapi) ---------------------------------------------------------
VAPI_API_KEY=
# Secreto para validar la firma de los webhooks de Vapi (end-of-call-report).
VAPI_WEBHOOK_SECRET=

# --- WhatsApp Cloud API (Meta) --------------------------------------------
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
# Token que tú eliges para verificar el webhook de Meta (handshake GET).
WHATSAPP_VERIFY_TOKEN=

# --- Email (Resend) --------------------------------------------------------
RESEND_API_KEY=
# Remitente de los avisos por email (dominio verificado en Resend).
EMAIL_FROM="Curro <avisos@tudominio.com>"

# --- Pagos (Stripe) --------------------------------------------------------
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# --- App -------------------------------------------------------------------
# URL pública de la app (para enlaces en emails/WhatsApp y callbacks).
APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Si es "false", los adaptadores llaman a los proveedores reales.
# Por defecto (o "true") usan mocks: ideal para desarrollo y tests.
MOCK_PROVIDERS=true
