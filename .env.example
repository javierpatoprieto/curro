# =============================================================================
# AtiendeReformas — variables de entorno
# Copia este fichero a .env.local y rellena lo que necesites.
# En desarrollo, deja MOCK_PROVIDERS=true para no depender de cuentas externas.
# NUNCA subas .env.local al repositorio.
# =============================================================================

# --- Supabase --------------------------------------------------------------
# En Supabase: Project Settings → API. La "Project URL" y la "anon public" key.
# (En Next, el cliente de navegador necesita el prefijo NEXT_PUBLIC_.)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# La "service_role" key: SOLO servidor (webhooks, onboarding). Salta RLS.
SUPABASE_SERVICE_ROLE_KEY=

# --- Voz IA (Vapi) ---------------------------------------------------------
VAPI_API_KEY=
# Secreto para validar la firma de los webhooks de Vapi (end-of-call-report).
VAPI_WEBHOOK_SECRET=

# --- WhatsApp Cloud API (Meta) --------------------------------------------
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
# Token que tú eliges para verificar el webhook de Meta (handshake GET).
WHATSAPP_VERIFY_TOKEN=

# --- Email (Resend) --------------------------------------------------------
RESEND_API_KEY=
# Remitente de los avisos por email (dominio verificado en Resend).
EMAIL_FROM="Curro <avisos@tudominio.com>"

# --- Pagos (Stripe) --------------------------------------------------------
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# IDs de precio de cada plan (Stripe → Products → Prices).
STRIPE_PRICE_STARTER=
STRIPE_PRICE_PRO=
STRIPE_PRICE_PREMIUM=

# --- App -------------------------------------------------------------------
# URL pública de la app (para enlaces en emails/WhatsApp y callbacks).
APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Google Analytics 4 (Measurement ID, p.ej. G-XXXXXXXXXX). Opcional y público.
# Si se define, aparece el banner de consentimiento y GA4 carga solo al aceptar.
NEXT_PUBLIC_GA_ID=

# --- Tracking de conversión (publicidad) -----------------------------------
# Opcionales y públicos. Solo se cargan tras el consentimiento de cookies
# (mismo opt-in que GA4). Sin id, no se carga nada. Configúralos en Vercel.
# Meta Pixel ID (Meta Ads / Business Manager → Orígenes de datos).
NEXT_PUBLIC_META_PIXEL_ID=
# Google Ads Conversion ID, formato "AW-XXXXXXXXX" (Google Ads → Conversiones).
NEXT_PUBLIC_GOOGLE_ADS_ID=

# Superadmin: contraseña para entrar en /admin (panel de control del dueño del
# SaaS). Sin esta variable, /admin no deja entrar a nadie (fail-closed).
ADMIN_PASSWORD=
# Secreto con el que se firma el token de sesión de admin (NO la contraseña).
# Genera uno aleatorio: `openssl rand -hex 32`. Recomendado en producción.
ADMIN_SESSION_SECRET=

# --- Rate limit durable (Upstash Redis) ------------------------------------
# Opcional. Con ambas, el límite de los webhooks es global entre instancias
# (Upstash → Redis → REST). Sin ellas, se usa un contador en memoria por instancia.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- Cron de retención (RGPD) ----------------------------------------------
# Secreto que protege /api/cron/retencion. Vercel Cron lo envía como
# `Authorization: Bearer <CRON_SECRET>`. Sin él, el endpoint solo corre en dev.
# Genera uno con `openssl rand -hex 32`. Configúralo también en Vercel.
CRON_SECRET=
# Plazos de retención (días) — opcionales; si se omiten, se usan los canónicos
# (audio 30, transcripción 360, raw_payload 30, facturación 2190, cuenta 1825,
# logs 90). Ver lib/rgpd/retencion.ts.
# RETENCION_AUDIO_DIAS=30
# RETENCION_TRANSCRIPCION_DIAS=360
# RETENCION_RAW_PAYLOAD_DIAS=30
# RETENCION_LOGS_DIAS=90

# Si es "false", los adaptadores llaman a los proveedores reales.
# Por defecto (o "true") usan mocks: ideal para desarrollo y tests.
MOCK_PROVIDERS=true
